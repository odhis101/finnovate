{
  "expo": {
    "name": "Finnovate",
    "slug": "finnovate",
    "version": "1.0.0",
    "owner": "odhis101",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "primaryColor": "#8056A4",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8056A4"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/4027dc23-d32b-4790-9653-34175c9ed152",
      "checkAutomatically": "ON_LOAD",
      "enabled": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.finnovate.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8056A4"
      },
      "usesCleartextTraffic": true,
      "package": "com.finnovate.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-secure-store",
      "expo-local-authentication",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#8056A4",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "4027dc23-d32b-4790-9653-34175c9ed152"
      }
    }
  }
}
